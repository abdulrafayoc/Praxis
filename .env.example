# ============================================================
# Praxis Healthcare Voice Agent - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# OpenAI (GPT-4o for agents, GPT-4o-mini for summarizer)
OPENAI_API_KEY=sk-...

# ElevenLabs (TTS - same voice for agent and filler audio)
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Deepgram (STT - Nova-2 model, <250ms latency)
DEEPGRAM_API_KEY=...

# Twilio (Voice + SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890
# WebSocket URL Pipecat connects to (must be publicly accessible)
TWILIO_WEBSOCKET_URL=wss://your-domain.com/ws/call
RECEPTIONIST_EXTENSION=100

# Database (PostgreSQL 16)
DATABASE_URL=postgresql+asyncpg://praxis:praxis_secret@postgres:5432/praxis

# Redis 7 (Session state + Celery broker)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# Admin Dashboard Auth (JWT)
JWT_SECRET=change-me-to-a-long-random-secret-minimum-32-characters
ADMIN_USERNAME=admin
# Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=$2b$12$changeme

# Application
DEBUG=false
MAX_CONCURRENT_CALLS=5
CONTEXT_MAX_TOKENS=3000
